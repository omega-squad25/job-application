block content
  // Include the textField component
  include ../components/textField

  .login-container
    .login-left
      img(src='/assets/images/LoginImg.png' alt='Login Image' class='login-img')

    .login-right
      div.logo
        a.logo-link(href='/')
          img(src='/assets/images/logo.svg' alt='Logo' class='logo')
      h2 Login to your account

      form.login-form(action='/api/auth/login' method='POST' id='loginForm')
        .form-group
          +textField('email', 'Enter your email', 'email', 'outlined')
        
        .form-group 
          +textField('password', 'Enter your password', 'password', 'outlined')

        .form-group 
          a.forgot-password(href='') Forgot Password?
        button.login-btn(type='submit') Login

      p.dont-have-account
        span Don't have an account?
        a.signup-link(href='/signUp')  Sign Up

block styles
  link(rel='stylesheet', href='/css/login.css')
  link(rel='stylesheet', href='/css/global-styles.css')
  link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css")

block scripts
  script(src="https://code.jquery.com/jquery-3.6.0.min.js")
  script(src='https://cdn.jsdelivr.net/npm/yup@0.32.9/dist/yup.min.js')
  script(src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js")
  script(src='/js/login.js')